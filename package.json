{
  "name": "@aurelienbbn/agentlint",
  "version": "0.1.5",
  "description": "Deterministic triggers for contextual agent guidance and accountable resolution",
  "keywords": [
    "agent",
    "ai",
    "ast",
    "code-review",
    "linter",
    "tanstack-intent",
    "tree-sitter"
  ],
  "license": "MIT",
  "author": "Aurelien Bobenrieth",
  "repository": {
    "type": "git",
    "url": "https://github.com/aurelienbobenrieth/agentlint"
  },
  "bin": {
    "agentlint": "dist/bin.mjs"
  },
  "files": [
    "dist",
    "skills",
    "!skills/_artifacts"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint",
    "fmt": "oxfmt --write",
    "fmt:check": "oxfmt --check",
    "changeset": "changeset",
    "check": "pnpm typecheck && pnpm lint && pnpm fmt:check && intent validate && pnpm test"
  },
  "dependencies": {
    "@effect/platform-node": "4.0.0-beta.85",
    "effect": "4.0.0-beta.85",
    "jiti": "^2.7.0",
    "picomatch": "^4.0.4",
    "web-tree-sitter": "^0.25.10"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@effect/language-service": "^0.86.2",
    "@tanstack/intent": "latest",
    "@types/node": "^22.20.0",
    "@types/picomatch": "^4.0.3",
    "oxfmt": "latest",
    "oxlint": "^1.71.0",
    "tree-sitter-wasms": "^0.1.13",
    "tsdown": "latest",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.28.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild",
      "msgpackr-extract"
    ],
    "ignoredBuiltDependencies": [
      "@parcel/watcher",
      "esbuild",
      "msgpackr-extract"
    ]
  }
}
