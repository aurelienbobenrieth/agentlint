{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "error",
    "perf": "error",
    "suspicious": "error"
  },
  "env": {
    "builtin": true,
    "node": true
  },
  "ignorePatterns": ["**/*.d.ts", ".agents/**", "**/*.wasm", "**/__fixtures__/**"],
  "plugins": ["eslint", "typescript", "unicorn", "vitest", "node", "promise"],
  "jsPlugins": ["./scripts/oxlint-plugin-agentlint.js"],
  "rules": {
    "agentlint/no-raw-json-parse": "error",
    "eslint/no-underscore-dangle": ["error", { "allow": ["_tag", "_tree", "__dirname", "__AGENTLINT_VERSION__"] }],
    "typescript/no-explicit-any": "error",
    "typescript/no-non-null-assertion": "error",
    "unicorn/filename-case": ["error", { "case": "kebabCase" }],
    "jest/no-conditional-expect": "off",
    "jest/valid-expect": "off",
    "jest/no-standalone-expect": "off",
    "jest/expect-expect": "off"
  }
}
